{
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(do echo:*)",
      "Bash(docker ps:*)",
      "Bash(gem:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(nmap.exe:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(ping:*)",
      "Bash(python:*)",
      "Bash(python -m pip:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:maclookup.app)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -Command \"Import-Module BurntToast; New-BurntToastNotification -Text 'Claude Code','Permission needed - a tool is waiting for approval'\""
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -Command \"Import-Module BurntToast; New-BurntToastNotification -Text 'Claude Code','Task complete - waiting for your input'\""
          }
        ]
      }
    ]
  }
}
