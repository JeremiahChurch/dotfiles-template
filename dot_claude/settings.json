      "Bash(column:*)",
      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(df:*)",
      "Bash(diff:*)",
      "Bash(dig:*)",
      "Bash(do echo:*)",
      "Bash(docker inspect:*)",
      "Bash(docker logs:*)",
      "Bash(docker ps:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(free:*)",
      "Bash(gem:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(hostname:*)",
      "Bash(id:*)",
      "Bash(ip:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(md5sum:*)",
      "Bash(nmap.exe:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(nslookup:*)",
      "Bash(ping:*)",
      "Bash(printf:*)",
      "Bash(pwd:*)",
      "Bash(python:*)",
      "Bash(python -m pip:*)",
      "Bash(sed:*)",
      "Bash(sha256sum:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(tac:*)",
      "Bash(tail:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(uname:*)",
      "Bash(uniq:*)",
      "Bash(uptime:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(xxd:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:maclookup.app)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Read(///mnt/c/Users/jerem/Pictures/Screenpresso/*)",
      "WebSearch"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -Command \"Import-Module BurntToast; New-BurntToastNotification -Text 'Claude Code','Permission needed - a tool is waiting for approval'\""
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -Command \"Import-Module BurntToast; New-BurntToastNotification -Text 'Claude Code','Task complete - waiting for your input'\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
