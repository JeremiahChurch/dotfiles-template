#!/bin/bash
# Install Docker Engine natively in WSL (replaces Docker Desktop's WSL integration)
#
# What this does:
#   1. Removes any old/conflicting Docker packages
#   2. Installs Docker Engine from Docker's official apt repo
#   3. Adds your user to the 'docker' group (no sudo needed for docker commands)
#   4. Enables and starts the Docker service via systemd
#
# After running this, you should:
#   - Uninstall Docker Desktop from Windows (Settings > Apps, or: winget uninstall Docker.DockerDesktop)
#   - Open a new WSL shell (group membership takes effect on new sessions)

set -e

if command -v dockerd &>/dev/null; then
    echo "Native Docker Engine is already installed: $(docker --version)"
    echo "Service status:"
    systemctl is-active docker 2>/dev/null || echo "  docker service is not running — try: sudo systemctl start docker"
    exit 0
fi

echo "=== Installing Docker Engine natively in WSL ==="
echo ""

# Remove old/conflicting packages (Docker Desktop leftovers, old docker.io, etc.)
echo "Removing conflicting packages..."
for pkg in docker.io docker-doc docker-compose docker-compose-v2 podman-docker containerd runc; do
    sudo apt-get remove -y "$pkg" 2>/dev/null || true
done

# Install prerequisites
echo "Installing prerequisites..."
sudo apt-get update
sudo apt-get install -y ca-certificates curl

# Add Docker's official GPG key
echo "Adding Docker apt repository..."
sudo install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
sudo chmod a+r /etc/apt/keyrings/docker.gpg

# Add the Docker apt repository
echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu \
$(. /etc/os-release && echo "$VERSION_CODENAME") stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

# Install Docker Engine
echo "Installing Docker Engine..."
sudo apt-get update
sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

# Add current user to docker group
if ! groups "$USER" | grep -qw docker; then
    echo "Adding $USER to docker group..."
    sudo usermod -aG docker "$USER"
    echo "  (group change takes effect in new shell sessions)"
fi

# Enable and start Docker via systemd
if command -v systemctl &>/dev/null && systemctl is-system-running &>/dev/null 2>&1; then
    echo "Enabling Docker service..."
    sudo systemctl enable docker
    sudo systemctl start docker
else
    echo ""
    echo "NOTE: systemd not detected. You may need to start Docker manually:"
    echo "  sudo dockerd &"
    echo ""
    echo "To enable systemd in WSL, add to /etc/wsl.conf:"
    echo "  [boot]"
    echo "  systemd=true"
    echo "Then restart WSL: wsl --shutdown"
fi

echo ""
echo "=== Docker Engine installed: $(docker --version) ==="
echo ""
echo "Next steps:"
echo "  1. Open a new WSL terminal (for docker group to take effect)"
echo "  2. Test with: docker run hello-world"
echo "  3. Uninstall Docker Desktop from Windows:"
echo "     winget uninstall Docker.DockerDesktop"
