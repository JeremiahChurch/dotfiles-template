# Force LF everywhere — repo storage AND working tree on all platforms.
# Without this, Windows git (core.autocrlf=true) converts LF→CRLF on
# checkout, which breaks shell scripts and configs used in WSL/Linux.
* text eol=lf

# Windows batch/script files need CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
